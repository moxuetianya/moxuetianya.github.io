&lt;span class=&quot;giallo-l&quot;&gt;&lt;span style=&quot;color: #FE4450;&quot;&gt;aplay&lt;&#x2F;span&gt;&lt;span style=&quot;color: #F97E72;&quot;&gt; -D&lt;&#x2F;span&gt;&lt;span&gt; hw:0,3 &#x2F;usr&#x2F;share&#x2F;sounds&#x2F;alsa&#x2F;Front_Left.wav&lt;&#x2F;span&gt;&lt;&#x2F;span&gt;
