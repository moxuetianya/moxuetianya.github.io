&lt;span class=&quot;giallo-l&quot;&gt;&lt;span style=&quot;color: #848BBD;font-style: italic;&quot;&gt;# 地址非53端口的所有流量&lt;&#x2F;span&gt;&lt;&#x2F;span&gt;
&lt;span class=&quot;giallo-l&quot;&gt;&lt;span style=&quot;color: #FE4450;&quot;&gt;9002:&lt;&#x2F;span&gt;&lt;span&gt; not from all dport&lt;&#x2F;span&gt;&lt;span style=&quot;color: #F97E72;&quot;&gt; 53&lt;&#x2F;span&gt;&lt;span&gt; lookup main suppress_prefixlength&lt;&#x2F;span&gt;&lt;span style=&quot;color: #F97E72;&quot;&gt; 0&lt;&#x2F;span&gt;&lt;&#x2F;span&gt;
