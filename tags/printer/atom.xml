&lt;span class=&quot;giallo-l&quot;&gt;&lt;span style=&quot;color: #FE4450;&quot;&gt;lp&lt;&#x2F;span&gt;&lt;span style=&quot;color: #F97E72;&quot;&gt; -d&lt;&#x2F;span&gt;&lt;span&gt; M329 file.pdf&lt;&#x2F;span&gt;&lt;span style=&quot;color: #848BBD;font-style: italic;&quot;&gt;           # 指定打印机&lt;&#x2F;span&gt;&lt;&#x2F;span&gt;
&lt;span class=&quot;giallo-l&quot;&gt;&lt;span style=&quot;color: #FE4450;&quot;&gt;lp&lt;&#x2F;span&gt;&lt;span style=&quot;color: #F97E72;&quot;&gt; -o&lt;&#x2F;span&gt;&lt;span&gt; sides=two-sided-long-edge file.pdf&lt;&#x2F;span&gt;&lt;span style=&quot;color: #848BBD;font-style: italic;&quot;&gt;  # 双面（长边翻转）&lt;&#x2F;span&gt;&lt;&#x2F;span&gt;
