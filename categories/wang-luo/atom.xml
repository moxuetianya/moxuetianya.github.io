&lt;span class=&quot;giallo-l&quot;&gt;&lt;span&gt;         NGX_SMP_LOCK  &lt;&#x2F;span&gt;&lt;&#x2F;span&gt;
&lt;span class=&quot;giallo-l&quot;&gt;&lt;span style=&quot;color: #FF8B39;&quot;&gt;    &amp;quot;    cmpxchgl  %3, %1;   &amp;quot;&lt;&#x2F;span&gt;&lt;span&gt;  &lt;&#x2F;span&gt;&lt;&#x2F;span&gt;
