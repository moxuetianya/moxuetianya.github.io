&lt;span class=&quot;giallo-l&quot;&gt;&lt;span&gt;    export SSH_AUTH_SOCK=&amp;quot;$(gpgconf --list-dirs agent-ssh-socket)&amp;quot;&lt;&#x2F;span&gt;&lt;&#x2F;span&gt;
&lt;span class=&quot;giallo-l&quot;&gt;&lt;span&gt;fi&lt;&#x2F;span&gt;&lt;&#x2F;span&gt;
&lt;span class=&quot;giallo-l&quot;&gt;&lt;span&gt;export GPG_TTY=$(tty)&lt;&#x2F;span&gt;&lt;&#x2F;span&gt;
