&lt;span class=&quot;giallo-l&quot;&gt;&lt;span&gt;*COREDNS_ADDR: &amp;quot;SERVER_PUBLIC_IP&amp;quot;*&lt;&#x2F;span&gt;&lt;&#x2F;span&gt;
&lt;span class=&quot;giallo-l&quot;&gt;&lt;&#x2F;span&gt;
