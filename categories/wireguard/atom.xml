&lt;pre class=&quot;giallo&quot; style=&quot;color: #FFFFFF; background-color: #262335;&quot;&gt;&lt;code data-lang=&quot;plain&quot;&gt;&lt;span class=&quot;giallo-l&quot;&gt;&lt;span&gt;SERVER_IP=$(ip route get 1 | sed -n &amp;#39;s&#x2F;^.*src \([0-9.]*\) .*$&#x2F;\1&#x2F;p&amp;#39;)&lt;&#x2F;span&gt;&lt;&#x2F;span&gt;
