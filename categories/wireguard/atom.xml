&lt;span class=&quot;giallo-l&quot;&gt;&lt;span&gt;dashboard.domain&lt;&#x2F;span&gt;&lt;&#x2F;span&gt;
&lt;span class=&quot;giallo-l&quot;&gt;&lt;span&gt;api.domain&lt;&#x2F;span&gt;&lt;&#x2F;span&gt;
